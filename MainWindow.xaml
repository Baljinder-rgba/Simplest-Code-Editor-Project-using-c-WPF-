<Window
    x:Class="bEdit.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:bEdit"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    MinWidth="1000"
    MinHeight="650"
    AllowsTransparency="True"
    MouseLeftButtonDown="Window_MouseLeftButtonDown"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>
        <Style x:Key="MinButton" TargetType="Button">
            <Setter Property="Background" Value="Gray" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderThickness" Value="0" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="SkyBlue" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Gray" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderThickness" Value="0" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="Red" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding
            Key="S"
            Command="ApplicationCommands.Save"
            Modifiers="Control" />
    </Window.InputBindings>

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Save" Executed="SaveFile" />
    </Window.CommandBindings>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="30" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Content  -->

        <!--  Title/Tool  Bar  -->
        <DockPanel
            x:Name="TitleBar"
            Grid.Row="0"
            Background="Gray"
            LastChildFill="False">

            <Image
                Width="20"
                Height="20"
                Margin="2,0,2,0"
                Source="/bEdit_Icon.png" />

            <StackPanel
                x:Name="Tools"
                DockPanel.Dock="Left"
                Orientation="Horizontal">
                <Button
                    Margin="2,0,2,0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Content="File"
                    Foreground="White">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Click="OpenFile" Header="Open File" />
                            <Separator />
                            <MenuItem Click="SaveFile" Header="Save" />
                            <Separator />
                            <MenuItem Click="CloseApp" Header="Exit" />
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                <Button
                    Margin="2,0,2,0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Click="OpenTerminal"
                    Content="Terminal"
                    Foreground="White" />
                <Button
                    Margin="2,0,2,0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    Content="About"
                    Foreground="White" />
            </StackPanel>

            <StackPanel
                x:Name="WindowButtons"
                DockPanel.Dock="Right"
                Orientation="Horizontal">
                <Button
                    Width="20"
                    Click="Button_Click_2"
                    Content="_"
                    Style="{StaticResource MinButton}" />
                <Button
                    Width="20"
                    Click="CloseApp"
                    Content="x"
                    Style="{StaticResource CloseButton}" />
            </StackPanel>
        </DockPanel>

        <!--  TextBox  -->
        <avalonEdit:TextEditor
            xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
            Name="TextEditor"
            Grid.Row="1"
            Padding="5,10,0,0"
            Background="#FF292929"
            FontFamily="./Fonts/# JetBrains Mono"
            FontSize="10pt"
            Foreground="White"
            HorizontalScrollBarVisibility="Hidden"
            ShowLineNumbers="True"
            SyntaxHighlighting="C#"
            VerticalScrollBarVisibility="Hidden" />

        <!--  Terminal  -->

    </Grid>
</Window>
